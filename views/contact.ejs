<%- include('partials/header') %>

<section class="contact">
    <h2>Контакты</h2>
    <div class="contact-info">
        <p><strong>Адрес:</strong> г. Москва, ул. Примерная, д. 1</p>
        <p><strong>Телефон:</strong> +7 (123) 456-78-90</p>
        <p><strong>Email:</strong> info@dentart.ru</p>
        <p><strong>Часы работы:</strong> пн-пт 9:00–21:00, сб 10:00–18:00, вс — выходной</p>
    </div>

    <h3>Запись на приём</h3>
    <% if (user) { %>
        <% if (user.role === 'patient') { %>
            <p><a href="/patient/new-appointment" class="btn">Перейти к записи</a></p>
        <% } else { %>
            <p>Только пациенты могут записываться. 
               <a href="/auth/logout">Выйти</a> и войти как пациент, или 
               <a href="/auth/register">зарегистрироваться</a>.</p>
        <% } %>
    <% } else { %>
        <p>Для записи на приём необходимо 
           <a href="/auth/login">войти</a> или 
           <a href="/auth/register">зарегистрироваться</a>.</p>
    <% } %>
</section>

<%- include('partials/footer') %>






