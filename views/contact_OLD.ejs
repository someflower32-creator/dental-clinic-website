<%- include('partials/header') %>

<section class="contact">
    <h2>Контакты и запись на приём</h2>
    <div class="contact-info">
        <p><strong>Адрес:</strong> г. Москва, ул. Примерная, д. 1</p>
        <p><strong>Телефон:</strong> +7 (123) 456-78-90</p>
        <p><strong>Email:</strong> info@dentart.ru</p>
        <p><strong>Часы работы:</strong> пн-пт 9:00–21:00, сб 10:00–18:00, вс — выходной</p>
    </div>

    <h3>Записаться на приём</h3>
    <form action="/appointment" method="POST" class="appointment-form" id="appointmentForm">
        <div class="form-group">
            <label for="name">Ваше имя *</label>
            <input type="text" id="name" name="name" required>
        </div>
        <div class="form-group">
            <label for="phone">Телефон *</label>
            <input type="tel" id="phone" name="phone" required pattern="\+?[0-9\s\-\(\)]+" title="Введите корректный номер">
        </div>
        <div class="form-group">
            <label for="service">Услуга</label>
            <select id="service" name="service_id">
                <option value="">-- Выберите услугу --</option>
                <% if (services && services.length) { %>
                    <% services.forEach(s => { %>
                        <option value="<%= s.id %>"><%= s.name %></option>
                    <% }) %>
                <% } %>
            </select>
        </div>
        <div class="form-group">
            <label for="date">Желаемая дата</label>
            <input type="date" id="date" name="date">
        </div>
        <button type="submit" class="btn">Отправить заявку</button>
    </form>
    <div id="formMessage"></div>
</section>

<%- include('partials/footer') %>


